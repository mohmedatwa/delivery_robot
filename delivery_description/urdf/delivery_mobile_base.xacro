<?xml version="1.0"?>

<robot name="delivery" xmlns:xacro="http://ros.org/wiki/xacro">
  
  <xacro:arg name="is_ignition" default="true" />
  <xacro:arg name="is_sim" default="True" />
  <xacro:include filename="$(find delivery_description)/urdf/sensors/ultrasonics.xacro" />
  <xacro:include filename="$(find delivery_description)/urdf/sensors/realsense_d435.xacro" />
  <xacro:include filename="$(find delivery_description)/urdf/sensors/imu.xacro" />
  <xacro:include filename="$(find delivery_description)/urdf/sensors/lidar.xacro" />

  <!-- Include Gazebo Parameters-->
  <xacro:include filename="$(find delivery_description)/urdf/delivery_gazebo.xacro"/>

  <!-- ROS2 Control-->
  <xacro:include filename="$(find delivery_description)/urdf/delivery_ros2_control.xacro"/>

  <link name="base_footprint" />
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass
        value="50" />
      <inertia
        ixx="0.190013298612022"
        ixy="0"
        ixz="0"
        iyy="0.194102599343596"
        iyz="0"
        izz="0.328271696632787" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0.1"
        rpy="0 0 0" />
      <geometry>
        <mesh filename="package://delivery_description/meshes/base_link.STL" />
      </geometry>
      <material name="black" />
      
        
    </visual>
    <collision>
      <origin
        xyz="0 0 0.1"
        rpy="0 0 0" />
      <geometry>
        <mesh filename="package://delivery_description/meshes/base_link.STL" />
      </geometry>
    </collision>
  
  </link>
  <joint name="base_joint" type="fixed">
      <parent link="base_footprint" />
      <child link="base_link" />
      <origin xyz="0 0 0.11" rpy="0 0 0"/>
  </joint>

  <link name="front_left_wheel">
    <inertial>
      <origin
        xyz="0 0 0"
        rpy="1.5708 0 0" />
      <mass
        value="0.26661498322291" />
      <inertia
        ixx="8.05457942683617E-05"
        ixy="0"
        ixz="0"
        iyy="8.05457942749361E-05"
        iyz="0"
        izz="9.3195603890608E-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0.03 0"
        rpy="1.5708 0 0" />
      <geometry>
        <mesh filename="package://delivery_description/meshes/Front_Left_Wheel.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="1.5708 0 0" />
      <geometry>
        <sphere radius="0.05" />
      </geometry>
    </collision>
  </link>
  <joint name="front_left_wheel_joint"
    type="continuous">
    <origin
      xyz="0.19721 0.24498 -0.05567"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="front_left_wheel" />
    <axis
      xyz="0 1 0" />
    <limit
      effort="180"
      velocity="50" />
    <!-- <dynamics
      damping="0.1"
      friction="0.1" /> -->
  </joint>

  <link name="front_right_wheel">
    <inertial>
      <origin
        xyz="0 0 0"
        rpy="1.5708 0 0" />
      <mass
        value="0.266614983222909" />
      <inertia
        ixx="8.05457942683617E-05"
        ixy="0"
        ixz="0"
        iyy="8.05457942749361E-05"
        iyz="0"
        izz="9.3195603890608E-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 -0.03 0"
        rpy="1.5708 0 0" />
      <geometry>
        <mesh filename="package://delivery_description/meshes/Right_Front_Wheel.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="1.5708 0 0" />
      <geometry>
        <sphere radius="0.05" />
      </geometry>
    </collision>
  </link>
  <joint name="front_right_wheel_joint"
    type="continuous">
    <origin
      xyz="0.19721 -0.24502 -0.05567"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="front_right_wheel" />
    <axis
      xyz="0 1 0" />
    <limit
      effort="180"
      velocity="50" />
    <!-- <dynamics
      damping="0.1"
      friction="0.1" /> -->
  </joint>

  <link name="back_left_wheel">
    <inertial>
      <origin
        xyz="0 0 0"
        rpy="1.5708 0 0" />
      <mass
        value="0.266614983222911" />
      <inertia
        ixx="8.05457942683617E-05"
        ixy="0"
        ixz="0"
        iyy="8.05457942749361E-05"
        iyz="0"
        izz="9.3195603890608E-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0.03 0"
        rpy="1.5708 0 0" />
      <geometry>
        <mesh filename="package://delivery_description/meshes/Left_Back_wheel.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="1.5708 0 0" />
      <geometry>
        <sphere radius="0.05" />
      </geometry>
    </collision>
  </link>
  <joint name="back_left_wheel_joint"
    type="continuous">
    <origin
      xyz="-0.19721 0.24498 -0.05567"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="back_left_wheel" />
    <axis
      xyz="0 1 0" />
    <limit
      effort="180"
      velocity="50" />
    <!-- <dynamics
      damping="0.1"
      friction="0.1" /> -->
  </joint>
  <link name="back_right_wheel">
    <inertial>
      <origin
        xyz="0 0 0"
        rpy="1.5708 0 0" />
      <mass
        value="0.266614983222911" />
      <inertia
        ixx="8.05457942683617E-05"
        ixy="0"
        ixz="0"
        iyy="8.05457942749361E-05"
        iyz="0"
        izz="9.3195603890608E-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 -0.03 0"
        rpy="1.5708 0 0" />
      <geometry>
        <mesh filename="package://delivery_description/meshes/Right_Bach_Wheel.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="1.5708 0 0" />
      <geometry>
        <sphere radius="0.05" />
      </geometry>
    </collision>
  </link>
  <joint name="back_right_wheel_joint"
    type="continuous">
    <origin
      xyz="-0.19721 -0.24502 -0.05567"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="back_right_wheel" />
    <axis
      xyz="0 1 0" />
    <limit
      effort="180"
      velocity="50" />
    <!-- <dynamics
      damping="0.1"
      friction="0.1" /> -->
  </joint>

  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="silver">
    <color rgba="0.79 0.82 0.93 1"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.3 0.3 0.3 1"/>
  </material>

</robot>
